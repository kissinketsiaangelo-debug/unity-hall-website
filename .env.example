# Unity Hall KNUST - Official Website
# Environment Variables Template
# Copy this file to .env.local and fill in your values

# Sanity CMS Configuration
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your_api_token
SANITY_STUDIO_URL=/studio

# NextAuth Configuration
NEXTAUTH_URL=https://unityhall.knust.edu.gh
NEXTAUTH_SECRET=your_super_secret_key_at_least_32_chars
AUTH_GOOGLE_ID=your_google_client_id
AUTH_GOOGLE_SECRET=your_google_client_secret
AUTH_GITHUB_ID=your_github_client_id
AUTH_GITHUB_SECRET=your_github_client_secret

# Database (Supabase/PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/unityhall
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=Unity Hall <noreply@unityhall.knust.edu.gh>

# Payment (Hubtel/ExpressPay for Mobile Money)
HUBTEL_CLIENT_ID=your_client_id
HUBTEL_CLIENT_SECRET=your_client_secret
HUBTEL_MERCHANT_ACCOUNT=your_merchant_account
EXPRESSPAY_API_KEY=your_expresspay_key
EXPRESSPAY_MERCHANT_ID=your_merchant_id

# Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=unityhall.knust.edu.gh

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_PWA=true
NEXT_PUBLIC_ENABLE_CHAT=false

# reCAPTCHA (for forms)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_site_key
RECAPTCHA_SECRET_KEY=your_secret_key

# CDN/Storage
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
AWS_S3_BUCKET=your_bucket
AWS_S3_REGION=your_region
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# KNUST Integration (future SSO)
KNUST_SSO_ENABLED=false
KNUST_SSO_CLIENT_ID=your_sso_client_id
KNUST_SSO_CLIENT_SECRET=your_sso_client_secret
KNUST_SSO_AUTH_URL=https://apps.knust.edu.gh/oauth/authorize
KNUST_SSO_TOKEN_URL=https://apps.knust.edu.gh/oauth/token
KNUST_SSO_USER_URL=https://apps.knust.edu.gh/api/user